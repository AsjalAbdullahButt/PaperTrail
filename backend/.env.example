# Copy this file to .env and fill in real values. NEVER commit .env.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- MySQL ---
# Recommended: create a dedicated least-privilege user (see README), not root.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=papertrail
DB_PASSWORD=change-me-strong-password
DB_NAME=papertrail

# --- Uploads / limits ---
# Max size (MB) for a single upload; larger uploads return HTTP 413.
MAX_UPLOAD_MB=25
# Max chunks a single RAG query will scan in memory (brute-force cosine).
MAX_QUERY_CHUNKS=5000

# --- CORS ---
# Comma-separated list of allowed browser origins for the frontend.
CORS_ORIGINS=http://localhost:3000

# --- Auth (JWT) ---
# MUST be overridden in production with a long random secret (>= 32 bytes),
# e.g. `openssl rand -hex 32`. Tokens are invalidated if this changes.
JWT_SECRET=dev-only-insecure-change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Redis / rate limiting / caching ---
# Set to share rate-limit counters and the query cache across API workers.
# Leave empty for single-worker / local dev (in-process fallback).
REDIS_URL=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_QUERY=60/minute
RATE_LIMIT_UPLOAD=20/minute
QUERY_CACHE_TTL_SECONDS=300

# --- SQLAlchemy connection pool ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
