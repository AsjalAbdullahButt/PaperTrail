# Copy this file to .env and fill in real values. NEVER commit .env.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- MySQL ---
# Recommended: create a dedicated least-privilege user (see README), not root.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=papertrail
DB_PASSWORD=change-me-strong-password
DB_NAME=papertrail
# Managed MySQL providers (e.g. Aiven) require TLS and reject plain
# connections outright. Set DB_SSL_MODE=true for those. DB_SSL_CA is the path
# to the provider's CA cert (Aiven console -> Overview -> CA Certificate,
# download and mount it, e.g. as a Render secret file at /etc/secrets/aiven-ca.pem).
# Leaving DB_SSL_CA empty with DB_SSL_MODE=true still works with most drivers
# (it negotiates TLS opportunistically) but does NOT verify the server
# certificate against a known CA, so it is weaker than pinning the CA file —
# fine to get started, but set DB_SSL_CA for a real production deployment.
DB_SSL_MODE=false
DB_SSL_CA=

# --- Uploads / limits ---
# Max size (MB) for a single upload; larger uploads return HTTP 413.
MAX_UPLOAD_MB=25
# Max chunks a single RAG query will scan in memory (brute-force cosine).
MAX_QUERY_CHUNKS=5000

# --- Storage backend (backend/app/storage.py) ---
# "local" (dev default: files under ./uploads/) or "s3" (any S3-compatible
# object store — AWS S3, Cloudflare R2, etc).
STORAGE_BACKEND=local
# Required when STORAGE_BACKEND=s3.
S3_BUCKET=
# "auto" works for Cloudflare R2; use a real AWS region (e.g. us-east-1) for S3.
S3_REGION=auto
# Leave empty for real AWS S3. For Cloudflare R2, use your account's S3 API
# endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
# R2: create these under R2 > Manage API Tokens. AWS: an IAM user/role scoped
# to this bucket only (s3:GetObject/PutObject/DeleteObject/HeadObject).
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- CORS ---
# Comma-separated list of allowed browser origins for the frontend.
CORS_ORIGINS=http://localhost:3000

# --- Auth (JWT) ---
# MUST be overridden in production with a long random secret (>= 32 bytes),
# e.g. `openssl rand -hex 32`. Tokens are invalidated if this changes.
JWT_SECRET=dev-only-insecure-change-me-in-production-please
JWT_ALGORITHM=HS256
# Short-lived access tokens (minutes). Refresh tokens (below) mint new ones.
JWT_EXPIRE_MINUTES=30
# Refresh-token lifetime (days). Delivered as an httpOnly cookie.
REFRESH_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=papertrail_refresh
# Set true in production (HTTPS) so the refresh cookie is Secure-only.
COOKIE_SECURE=false

# --- Redis / rate limiting / caching ---
# Set to share rate-limit counters and the query cache across API workers.
# Leave empty for single-worker / local dev (in-process fallback).
REDIS_URL=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_QUERY=60/minute
RATE_LIMIT_UPLOAD=20/minute
QUERY_CACHE_TTL_SECONDS=300

# --- SQLAlchemy connection pool ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
